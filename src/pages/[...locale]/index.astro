---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Footer from '../../components/Footer.astro';
import ProjectCatalog from '../../components/ProjectCatalog';
import ProjectHealthInit from '../../components/ProjectHealthInit';
import { locales, defaultLocale, getLocaleParam, type Locale } from '../../i18n/config';
import { getTranslations } from '../../i18n/ui';
import { getProjects } from '../../i18n/projects';
import site from '../../data/site.json';

export function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale: getLocaleParam(locale) },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
const t = getTranslations(locale);
const projectList = getProjects(locale);
const categories = [...new Set(projectList.map((p) => p.category))];
---

<BaseLayout locale={locale} t={t}>
  <ProjectHealthInit projects={projectList} client:load />
  <main class="flex-1 w-full space-y-4">
    <Hero
      t={t}
      projectCount={projectList.length}
      projects={projectList}
    />

    <div class="container-main pb-20">
      <ProjectCatalog
        projects={projectList}
        categories={categories}
        t={t}
        client:load
      />
    </div>
  </main>

  <Footer
    t={t}
    domain={site.domain}
    email={site.email}
    github={site.github}
  />
</BaseLayout>
