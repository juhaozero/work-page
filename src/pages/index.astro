---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import ProjectCatalog from '../components/ProjectCatalog';
import projects from '../data/projects.json';
import site from '../data/site.json';
import type { Project } from '../types/project';

const projectList = projects as Project[];
const categories = [...new Set(projectList.map((p) => p.category))];
---

<BaseLayout>
  <main class="flex-1 w-full space-y-4">
    <Hero
      title={site.title}
      eyebrow={site.eyebrow}
      heroTitle={site.heroTitle}
      heroDescription={site.heroDescription}
      tagline={site.tagline}
      projectCount={projectList.length}
      projects={projectList}
    />

    <div class="container-main pb-20">
      <ProjectCatalog projects={projectList} categories={categories} client:load />
    </div>
  </main>

  <Footer
    title={site.title}
    domain={site.domain}
    tagline={site.tagline}
    email={site.email}
    github={site.github}
  />
</BaseLayout>
