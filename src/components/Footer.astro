---
import type { UITranslations } from '../i18n/ui';

interface Props {
  t: UITranslations;
  domain: string;
  email: string;
  github: string;
}

const { t, domain, email, github } = Astro.props;
const year = new Date().getFullYear();
const divider = '';
---

<footer class="mt-auto container-main py-12">
  <p class="terminal-divider mb-6">{divider}</p>

  <div
    class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 text-xs pt-6"
    style="border-top: 1px solid var(--crt-border-dim); color: var(--crt-text-muted);"
  >
    <div class="space-y-2">
      <p class="leading-relaxed">
        <span style="color: var(--crt-text);">{t.site.title}</span>
        <span class="hidden sm:inline"> · {t.site.tagline}</span>
        <span> · © {year}{domain ? ` ${domain}` : ''}</span>
      </p>
    </div>

    <div class="flex items-center gap-4">
      <a
        href={`mailto:${email}`}
        class="btn-terminal text-xs"
      >
        {t.footer.contact}
      </a>
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-terminal text-xs"
      >
        {t.footer.github}
      </a>
    </div>
  </div>
</footer>
