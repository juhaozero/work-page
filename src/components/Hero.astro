---
import FeaturedProjects from './FeaturedProjects';
import type { Project } from '../types/project';

interface Props {
  title: string;
  eyebrow: string;
  heroTitle: string;
  heroDescription: string;
  tagline: string;
  projectCount: number;
  projects: Project[];
}

const { eyebrow, heroTitle, heroDescription, tagline, projectCount, projects } = Astro.props;
const featuredProjects = projects.filter((p) => p.featured);
const divider = '';
---

<section class="container-main pt-24 sm:pt-28 pb-12">
  <p class="terminal-divider mb-6">{divider}</p>

  <div class={`grid gap-10 lg:gap-16 items-start ${featuredProjects.length > 0 ? 'lg:grid-cols-2' : ''}`}>
    <div class="space-y-6">
      <div class="space-y-5">
        <p class="terminal-label">{eyebrow}</p>

        <h1 class="text-2xl sm:text-3xl md:text-4xl font-semibold leading-snug tracking-tight whitespace-pre-line">
          {heroTitle}
        </h1>

        <p class="text-sm leading-relaxed max-w-lg" style="color: var(--crt-text-muted);">
          {heroDescription}
        </p>

        <p class="text-sm" style="color: var(--crt-text-dim);">{tagline}</p>
      </div>

      <div class="flex flex-wrap gap-2 pt-1">
        <span class="pill-terminal">
          共 <strong class="font-semibold tabular-nums" style="color: var(--crt-text);">{projectCount}</strong> 个项目
        </span>
        {featuredProjects.length > 0 && (
          <span class="pill-terminal">
            <strong class="font-semibold tabular-nums" style="color: var(--crt-text);">{featuredProjects.length}</strong> 个精选
          </span>
        )}
      </div>
    </div>

    {featuredProjects.length > 0 && (
      <FeaturedProjects projects={featuredProjects} client:load />
    )}
  </div>
</section>
