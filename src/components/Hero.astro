---
import type { Project } from '../types/project';

interface Props {
  title: string;
  eyebrow: string;
  heroTitle: string;
  heroDescription: string;
  tagline: string;
  projectCount: number;
  projects: Project[];
}

const { title, eyebrow, heroTitle, heroDescription, tagline, projectCount, projects } = Astro.props;
const featuredProjects = projects.filter((p) => p.featured);
---

<section class="container-main pt-20 sm:pt-28 pb-12">
  <div class={`grid gap-10 lg:gap-16 items-center ${featuredProjects.length > 0 ? 'lg:grid-cols-2' : ''}`}>
    <div class="space-y-8">
      <p class="text-sm text-zinc-500">
        {title} · {tagline}
      </p>

      <div class="space-y-5">
        <p class="text-xs font-medium tracking-wide text-zinc-400 dark:text-zinc-500">
          {eyebrow}
        </p>

        <h1 class="text-3xl sm:text-4xl md:text-[2.75rem] font-semibold leading-[1.25] tracking-tight text-zinc-900 dark:text-zinc-50 whitespace-pre-line">
          {heroTitle}
        </h1>

        <p class="text-base text-zinc-500 leading-relaxed max-w-lg">
          {heroDescription}
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <span class="pill-muted">
          共 <strong class="font-medium text-zinc-800 dark:text-zinc-200 tabular-nums">{projectCount}</strong> 个项目
        </span>
        {featuredProjects.length > 0 && (
          <span class="pill-muted">
            <strong class="font-medium text-zinc-800 dark:text-zinc-200 tabular-nums">{featuredProjects.length}</strong> 个精选
          </span>
        )}
      </div>
    </div>

    {featuredProjects.length > 0 && (
      <div class="space-y-4" aria-label="精选项目">
        <p class="text-xs font-medium tracking-wide text-zinc-400 dark:text-zinc-500">精选项目</p>

        <div class="space-y-3">
          {featuredProjects.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="glass-card card-hover group flex items-center gap-4 p-4 sm:p-5 cursor-pointer"
            >
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-zinc-100/80 text-xl dark:bg-zinc-800/60">
                <span role="img" aria-label={project.name}>{project.emoji}</span>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="tag-muted">{project.category}</span>
                  <span class="text-xs text-zinc-400 dark:text-zinc-500">精选</span>
                </div>
                <h2 class="font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 truncate group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-all duration-300 ease-in-out">
                  {project.name}
                </h2>
                <p class="text-sm text-zinc-500 leading-relaxed line-clamp-1 mt-0.5">
                  {project.description}
                </p>
              </div>

              <span class="shrink-0 text-zinc-400 dark:text-zinc-500 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-all duration-300 ease-in-out" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17 17 7M7 7h10v10" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
