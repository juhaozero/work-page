---
import type { Project } from '../types/project';

interface Props {
  title: string;
  eyebrow: string;
  heroTitle: string;
  heroDescription: string;
  tagline: string;
  projectCount: number;
  projects: Project[];
}

const { eyebrow, heroTitle, heroDescription, tagline, projectCount, projects } = Astro.props;
const featuredProjects = projects.filter((p) => p.featured);
const divider = '';
---

<section class="container-main pt-24 sm:pt-28 pb-12">
  <p class="terminal-divider mb-6">{divider}</p>

  <div class={`grid gap-10 lg:gap-16 items-start ${featuredProjects.length > 0 ? 'lg:grid-cols-2' : ''}`}>
    <div class="space-y-6">
      <div class="space-y-5">
        <p class="terminal-label">{eyebrow}</p>

        <h1 class="text-2xl sm:text-3xl md:text-4xl font-semibold leading-snug tracking-tight whitespace-pre-line">
          {heroTitle}
        </h1>

        <p class="text-sm leading-relaxed max-w-lg" style="color: var(--crt-text-muted);">
          {heroDescription}
        </p>

        <p class="text-sm" style="color: var(--crt-text-dim);">{tagline}</p>
      </div>

      <div class="flex flex-wrap gap-2 pt-1">
        <span class="pill-terminal">
          共 <strong class="font-semibold tabular-nums" style="color: var(--crt-text);">{projectCount}</strong> 个项目
        </span>
        {featuredProjects.length > 0 && (
          <span class="pill-terminal">
            <strong class="font-semibold tabular-nums" style="color: var(--crt-text);">{featuredProjects.length}</strong> 个精选
          </span>
        )}
      </div>
    </div>

    {featuredProjects.length > 0 && (
      <div class="space-y-4" aria-label="精选项目">
        <p class="terminal-label">精选项目</p>

        <div class="space-y-3">
          {featuredProjects.map((project, i) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="terminal-card terminal-card-hover group flex items-center gap-4 p-4 sm:p-5 cursor-pointer"
            >
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center text-xl"
                style="border: 1px solid var(--crt-border-dim); background: var(--crt-bg);"
              >
                <span role="img" aria-label={project.name}>{project.emoji}</span>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="tag-terminal">项目 {String(i + 1).padStart(2, '0')}</span>
                  <span class="tag-terminal">{project.category}</span>
                  <span class="terminal-label">精选</span>
                </div>
                <h2 class="font-semibold tracking-tight truncate group-hover:opacity-80 transition-opacity duration-150">
                  {project.name}
                </h2>
                <p class="text-xs leading-relaxed line-clamp-1 mt-0.5" style="color: var(--crt-text-muted);">
                  {project.description}
                </p>
              </div>

              <span
                class="shrink-0 text-xs opacity-60 group-hover:opacity-100 transition-opacity duration-150"
                style="color: var(--crt-accent);"
                aria-hidden="true"
              >
                前往
              </span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
