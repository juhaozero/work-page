---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle';
import LanguageSwitcher from '../components/LanguageSwitcher';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { locales, localeHtmlLang, localeOgLocale, type Locale } from '../i18n/config';
import { aboutPath, homePath } from '../i18n/paths';
import type { UITranslations } from '../i18n/ui';
import site from '../data/site.json';

interface Props {
  locale: Locale;
  t: UITranslations;
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  /** 去掉语言前缀后的路径，供语言切换与 hreflang，如 `/`、`/about`、`/projects/foo` */
  path?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const siteUrl = site.url ?? `https://${site.domain}`;

const {
  locale,
  t,
  title,
  description,
  canonical,
  noindex = false,
  path = '/',
  ogImage: ogImageProp,
  jsonLd: jsonLdProp,
} = Astro.props;

const pageTitle = title ?? t.site.title;
const pageDescription = description ?? t.site.seo.description;
const pageUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const defaultOg = site.seo?.ogImage ? new URL(site.seo.ogImage, siteUrl).href : undefined;
const ogImage = ogImageProp
  ? new URL(ogImageProp, siteUrl).href
  : defaultOg;
const keywords = t.site.seo.keywords.join(', ');
const robots = noindex ? 'noindex, nofollow' : (site.seo?.robots ?? 'index, follow');
const htmlLang = localeHtmlLang[locale];
const ogLocale = localeOgLocale[locale];

const langLinks = locales.map((loc) => ({
  locale: loc,
  url: getRelativeLocaleUrl(loc, path),
}));

const hreflangLinks = locales.map((loc) => ({
  locale: loc,
  url: new URL(getRelativeLocaleUrl(loc, path), siteUrl).href,
}));

const jsonLd = jsonLdProp ?? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t.site.title,
  description: pageDescription,
  url: pageUrl,
  inLanguage: htmlLang,
  author: {
    '@type': 'Person',
    name: t.site.seo.author,
    email: site.email,
    url: site.github,
  },
};

const homeHref = homePath(locale);
const aboutHref = aboutPath(locale);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {keywords && <meta name="keywords" content={keywords} />}
    {t.site.seo.author && <meta name="author" content={t.site.seo.author} />}
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={pageUrl} />
    {hreflangLinks.map(({ locale: loc, url }) => (
      <link rel="alternate" hreflang={localeHtmlLang[loc]} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getRelativeLocaleUrl('zh', path), siteUrl).href} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t.site.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content={ogLocale} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Sans+Mono:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-mono">
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--crt-border-dim)] bg-[var(--crt-bg)]/95 backdrop-blur-sm">
      <div class="container-main flex items-center justify-between py-3">
        <div class="flex items-center gap-3 min-w-0">
          <span class="status-online shrink-0" aria-hidden="true">{t.nav.online}</span>
          <a href={homeHref} class="truncate hidden sm:inline hover:opacity-80 transition-opacity" style="color: var(--crt-text-muted);">
            {t.site.title}
          </a>
          <a
            href={aboutHref}
            class="text-xs shrink-0 hover:opacity-80 transition-opacity"
            style="color: var(--crt-text-dim);"
          >
            [{t.nav.about}]
          </a>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <LanguageSwitcher
            locale={locale}
            ariaLabel={t.langSwitcher.ariaLabel}
            links={langLinks}
            client:load
          />
          <ThemeToggle labels={t.theme} client:load />
        </div>
      </div>
    </header>
    <slot />
  </body>
</html>
